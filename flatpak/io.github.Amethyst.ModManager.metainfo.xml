<?xml version="1.0" encoding="UTF-8"?>
<!--
  AppStream metainfo — read by Discover / GNOME Software / Warehouse to show
  the app's name, description, and (crucially) its version + release history.

  The releases list is STAMPED AT BUILD TIME from src/version.py by the
  flatpak manifest (a sed step rewrites the @VERSION@ / @DATE@ tokens below),
  so this file never needs hand-editing per release. Without a matching
  release entry, package managers report "No version information found".
-->
<component type="desktop-application">
  <id>io.github.Amethyst.ModManager</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <name>Amethyst Mod Manager</name>
  <summary>Manage game mods on Linux and the Steam Deck</summary>

  <description>
    <p>
      Amethyst is a mod manager for Linux and the Steam Deck. It installs,
      orders, and deploys mods for a wide range of games, with Nexus Mods
      integration, collections, FOMOD/BAIN installers, LOOT sorting, and
      per-profile mod lists.
    </p>
  </description>

  <launchable type="desktop-id">io.github.Amethyst.ModManager.desktop</launchable>

  <url type="homepage">https://github.com/ChrisDKN/Amethyst-Mod-Manager</url>
  <url type="bugtracker">https://github.com/ChrisDKN/Amethyst-Mod-Manager/issues</url>

  <developer id="io.github.chrisdkn">
    <name>ChrisDKN</name>
  </developer>

  <content_rating type="oars-1.1" />

  <releases>
    <!-- Stamped at build time from src/version.py — do not hand-edit. -->
    <release version="@VERSION@" date="@DATE@"/>
  </releases>
</component>
